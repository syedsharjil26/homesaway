# Supabase Configuration (Template)
# Copy this file to .env.local and fill in your actual Supabase credentials

# Get these values from your Supabase project settings
# https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Storage bucket name for file uploads
EXPO_PUBLIC_SUPABASE_BUCKET_NAME=listings
